{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "4",
        "author": "Aydan",
        "changes": [
          {
            "createTable": {
              "tableName": "products",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": { "primaryKey": true, "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "name",
                    "type": "VARCHAR(255)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "description",
                    "type": "VARCHAR(1000)"
                  }
                },
                {
                  "column": {
                    "name": "price",
                    "type": "DECIMAL(19, 2)",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "status",
                    "type": "VARCHAR(50)"
                  }
                },
                {
                  "column": {
                    "name": "merchant_id",
                    "type": "UUID",
                    "constraints": {
                      "nullable": false,
                      "foreignKeyName": "fk_product_merchant",
                      "referencedTableName": "merchants",
                      "referencedColumnNames": "id"
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}